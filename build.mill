/** Aggregate command that runs every engine-relevant JVM test module - and validates each
  * one's Scoverage coverage minimums - for a single Scala version. This is the ONE place that
  * lists those modules: CI's `testJvm` job calls `testEngine` once per Scala version, so adding
  * a new engine test module here is the only change needed - `.github/workflows/ci.yml` never
  * has to be touched again.
  *
  * Failure propagation: `testForked()` and `validateCoverageMinimums()` both throw (via
  * `mill.api.Result.Failure`) when tests fail or coverage drops below the configured minimums.
  * Since this command body calls them directly and does not catch exceptions, any failure
  * aborts `testEngine` immediately with a non-zero exit code.
  */
def testEngine(scalaVersion: String) = Task.Command {
  h2Codec.jvm(scalaVersion).test.testForked()()
  h2Codec.jvm(scalaVersion).scoverage.validateCoverageMinimums()()
  serverLoom.jvm(scalaVersion).test.testForked()()
  serverLoom.jvm(scalaVersion).scoverage.validateCoverageMinimums()()
  zio.jvm(scalaVersion).test.testForked()()
  zio.jvm(scalaVersion).scoverage.validateCoverageMinimums()()
  endpoint.jvm(scalaVersion).test.testForked()()
  endpoint.jvm(scalaVersion).scoverage.validateCoverageMinimums()()
  testkit.jvm(scalaVersion).test.testForked()()
  testkit.jvm(scalaVersion).scoverage.validateCoverageMinimums()()
}

object testkit extends Module {
  val r = wsRoot / "zio-http-testkit"
  object jvm      extends Cross[JvmModule](scalaVersions)
  trait JvmModule extends ZioHttpJvmModule {
    def artifactName       = "zio-http-testkit"
    def moduleDeps         =
      Seq(core.jvm(), server.jvm(), client.jvm())
    override def mvnDeps   = super.mvnDeps() ++ Seq(
      mvn"dev.zio::zio:${Versions.Zio}",
      mvn"dev.zio::zio-test:${Versions.Zio}",
    )
    override def sources   = Task.Sources(r / "src" / "main" / "scala")
    override def resources = Task.Sources(r / "src" / "main" / "resources")
    object test extends ScoverageTests with ZioHttpTestModule {
      override def moduleDeps =
        Seq(testkit.jvm())
      override def sources    = Task.Sources(r / "src" / "test" / "scala")
      override def resources  = Task.Sources(r / "src" / "test" / "resources")
    }
  }
}

object benchmarks extends Module {
  val r = wsRoot / "zio-http-benchmarks"
  object jvm      extends Cross[JvmModule](scalaVersions)
  trait JvmModule extends ZioHttpModule with JmhModule {
    def artifactName     = "zio-http-benchmarks"
    def jmhCoreVersion   = "1.37"
    def moduleDeps       = Seq(core.jvm())
    override def mvnDeps = super[ZioHttpModule].mvnDeps() ++ super[JmhModule].mvnDeps()
    // NOTE: `r / "src" / "main" / "scala"` (the version-agnostic dir) intentionally excluded -
    // it holds pre-existing legacy pre-v4 zhttp/sbt-jmh benchmark sources (untouched by this
    // plan, not wired into any build before this todo, and not compiling against the current
    // API - same class of pre-existing dormant code as zio-http-example/zio-http-testkit per
    // Todo 7's findings). Only this todo's own new Scala-version-specific sources are compiled.
    override def sources = {
      val vDir = if (crossScalaVersion.startsWith("2.")) "scala-2" else "scala-3"
      Task.Sources(r / "src" / "main" / vDir)
    }
  }
}

