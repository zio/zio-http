object endpoint extends Module {
  val r = wsRoot / "zio-http-endpoint"
  object jvm      extends Cross[JvmModule](scalaVersions)
  trait JvmModule extends ZioHttpModule   {
    def artifactName     = "zio-http-endpoint"
    def moduleDeps       = Seq(core.jvm(), client.jvm())
    override def sources = {
      val vDir =
        if (crossScalaVersion.startsWith("2.")) "scala-2" else if (crossScalaVersion.startsWith("3.")) "scala-3" else ""
      val base = Seq(r / "shared" / "src" / "main" / "scala", r / "jvm" / "src" / "main" / "scala")
      Task.Sources((if (vDir.nonEmpty) base :+ (r / "shared" / "src" / "main" / vDir) else base) *)
    }
    object test extends ScalaTests with ZioHttpTestModule {
      override def moduleDeps =
        Seq(endpoint.jvm(), core.jvm().test, nettyCore.jvm(), nettyServer.jvm(), nettyClient.jvm())
      override def sources    = {
        val vDir =
          if (crossScalaVersion.startsWith("2.")) "scala-2"
          else if (crossScalaVersion.startsWith("3.")) "scala-3"
          else ""
        val base = Seq(r / "shared" / "src" / "test" / "scala", r / "jvm" / "src" / "test" / "scala")
        Task.Sources(
          (if (vDir.nonEmpty) base ++ Seq(r / "shared" / "src" / "test" / vDir, r / "jvm" / "src" / "test" / vDir)
           else base) *,
        )
      }
      override def resources  =
        Task.Sources(r / "shared" / "src" / "test" / "resources", r / "jvm" / "src" / "test" / "resources")
    }
  }
  object js       extends Cross[JsModule](scalaVersions)
  trait JsModule  extends ZioHttpJSModule {
    def artifactName     = "zio-http-endpoint"
    def moduleDeps       = Seq(core.js(), client.js())
    override def sources = {
      val vDir =
        if (crossScalaVersion.startsWith("2.")) "scala-2" else if (crossScalaVersion.startsWith("3.")) "scala-3" else ""
      val base = Seq(r / "shared" / "src" / "main" / "scala", r / "js" / "src" / "main" / "scala")
      Task.Sources((if (vDir.nonEmpty) base :+ (r / "shared" / "src" / "main" / vDir) else base) *)
    }
  }
}

object fetchClient extends Module {
  object js      extends Cross[JsModule](scalaVersions)
  trait JsModule extends ZioHttpJSModule {
    def artifactName     = "zio-http-fetch-client"
    def moduleDeps       = Seq(client.js())
    override def sources = Task.Sources(wsRoot / "zio-http-fetch-client" / "js" / "src" / "main" / "scala")
    override def mvnDeps = super.mvnDeps() ++ Seq(mvn"org.scala-js::scalajs-dom::2.8.1")
  }
}

object nettyCore extends Module {
  val r = wsRoot / "zio-http-netty-core"
  object jvm      extends Cross[JvmModule](scalaVersions)
  trait JvmModule extends ZioHttpModule {
    def artifactName            = "zio-http-netty-core"
    def moduleDeps              = Seq(core.jvm(), client.jvm())
    override def sources        = Task.Sources(r / "src" / "main" / "scala")
    override def resources      = Task.Sources(r / "src" / "main" / "resources")
    override def mvnDeps        = super.mvnDeps() ++ Seq(
      mvn"io.netty:netty-codec-http:${Versions.Netty}",
      mvn"io.netty:netty-handler-proxy:${Versions.Netty}",
      mvn"io.netty:netty-transport-native-epoll:${Versions.Netty}",
      mvn"io.netty:netty-transport-native-kqueue:${Versions.Netty}",
      mvn"io.netty:netty-transport-native-io_uring:${Versions.Netty}",
      mvn"io.netty:netty-pkitesting:${Versions.Netty}",
    )
    override def compileMvnDeps = super.compileMvnDeps() ++ Seq(
      mvn"com.aayushatharva.brotli4j:brotli4j:1.16.0",
    )
    object test extends ScalaTests with ZioHttpTestModule {
      override def moduleDeps = Seq(nettyCore.jvm(), core.jvm().test, nettyClient.jvm(), nettyServer.jvm())
      override def sources    = Task.Sources(r / "src" / "test" / "scala")
      override def resources  = Task.Sources(r / "src" / "test" / "resources")
    }
  }
}

