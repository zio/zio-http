object serverLoom extends Module {
  val r = wsRoot / "zio-http-server-loom"
  object jvm extends Cross[JvmModule](scalaVersions)
  trait JvmModule extends ZioHttpJvmModule {
    def artifactName     = "zio-http-server-loom"
    def moduleDeps       = Seq(server.jvm(), h2Codec.jvm())
    override def sources = Task.Sources(r / "src" / "main" / "scala")
    // Branch minimum is 75%: ~25% of branches are in private defensive Any-match arms
    // (toStream, toUnit, toOptionalFrame, toReceivedFrame, toSendError) that exist for
    // Mux API version compatibility and cannot be reached from outside the enclosing class.
    override def branchCoverageMin = Some(75.0)
    override def mvnDeps = super.mvnDeps() ++ Seq(
      blocksDep("mux"),
      blocksDep("scope"),
      blocksDep("streams"),
      blocksDep("telemetry"),
    )
    object test extends ScoverageTests with ZioHttpTestModule {
      override def moduleDeps = Seq(serverLoom.jvm(), clientJava.jvm())
      override def sources    = Task.Sources(r / "src" / "test" / "scala")
    }
  }
}

